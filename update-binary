#!/sbin/sh

#################
# Initialization
#################

umask 022

# echo before loading util_functions
ui_print() { echo "$1"; }

require_new_apk() {
  return 0  # 不需要 APK
}

require_new_ksud() {
  return 0  # 不需要 ksud
}

setup_flashable() {
  # 常规初始化
  BOOTMODE=true
  PS="ps"
  if [ -z "$OUTFD" ]; then
    # 如果 OUTFD 未设置，尝试从参数获取
    OUTFD=$2
  fi
  if [ ! -z $3 ]; then
    # 第三个参数是父进程 ID，但这里用不到
    :
  fi
  # 加载 util_functions
  if [ -f /data/adb/magisk/util_functions.sh ]; then
    . /data/adb/magisk/util_functions.sh
  elif [ -f /data/adb/ksu/util_functions.sh ]; then
    . /data/adb/ksu/util_functions.sh
  else
    ui_print "! Cannot find util_functions.sh"
    exit 1
  fi
  api_level_arch_detect
}

# 主流程
setup_flashable
ui_print "**********************"
ui_print "   swappiness150 模块  "
ui_print "**********************"
ui_print "- 目标: 设置 vm.swappiness=150"

# 解压模块文件到临时目录
ui_print "- 正在解压"
mkdir -p $MODPATH
unzip -o "$ZIPFILE" -x 'META-INF/*' -d $MODPATH >&2

# 设置权限
set_perm_recursive $MODPATH 0 0 0755 0644
set_perm $MODPATH/service.sh 0 0 0755

ui_print "- 安装完成"
exit 0
